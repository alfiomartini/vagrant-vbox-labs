Vagrant.configure("2") do |config|
  # Loop to define each VM explicitly and independently
  ["vm1", "vm2"].each do |name|
    config.vm.define name do |node|
      if name == "vm1"
         node.vm.network "forwarded_port", guest: 8080, host: 8081
      end
      # --- Local VM Settings ---
      node.vm.box = "debian/bookworm64"
      node.vm.hostname = name
      
      # Explicitly define the primary disk for this instance
      node.vm.disk :disk, name: "primary", size: "20GB"
      
      # Explicitly define the synced folder for this instance
      node.vm.synced_folder ".", "/vagrant", disabled: false

      # --- Local Provider Settings ---
      node.vm.provider "virtualbox" do |vb|
        vb.name = "lab_nat_#{name}"
        vb.memory = 1024
        vb.cpus = 2
        vb.gui = false

        # Explicitly set Adapter 1 to NAT mode for clarity
        vb.customize ["modifyvm", :id, "--nic1", "nat"]
      end
    end
  end
end

# --- Note on Configuration Strategy ---
# This Vagrantfile avoids global settings (inheritance) in favor of 'local' 
# configuration within the machine block. While slightly more repetitive, 
# this makes each VM definition self-contained and explicitly clear.
