# ==============================================================================
# IMPORTANT: SET YOUR HOST NETWORK INTERFACE HERE
# Replace "eth0" with your active interface (e.g., wlo1, wlan0, enp0s31f6).
# You can find it by running 'ip route | grep default' on your host.
# ==============================================================================
bridge_interface = "wlo1"

Vagrant.configure("2") do |config|
  # Using 2 VMs to demonstrate inter-VM connectivity on the physical LAN
  ["vm1", "vm2"].each do |name|
    config.vm.define name do |node|
      # --- Local VM Settings ---
      node.vm.box = "debian/bookworm64"
      node.vm.hostname = name
      node.vm.disk :disk, name: "primary", size: "20GB"
      node.vm.synced_folder ".", "/vagrant", disabled: false

      # --- Bridged Networking ---
      # use_dhcp_assigned_default_route: true ensures the bridged interface's
      # gateway is used instead of the NAT interface's default route
      node.vm.network "public_network", 
        bridge: bridge_interface,
        use_dhcp_assigned_default_route: true

      # --- Local Provider Settings ---
      node.vm.provider "virtualbox" do |vb|
        vb.name = "lab_bridged_#{name}"
        vb.memory = 1024
        vb.cpus = 2
        vb.gui = false
        # Explicitly define NIC 1 as NAT for Vagrant SSH management
        vb.customize ["modifyvm", :id, "--nic1", "nat"]
      end
    end
  end
end

# --- Note on Configuration Strategy ---
# This Vagrantfile resolves the 'Dual Gateway' conflict using Vagrant's built-in
# use_dhcp_assigned_default_route option:
# 1. Management: NIC 1 (NAT) is used for SSH.
# 2. Experiment: NIC 2 (Bridged) receives DHCP and its gateway is prioritized.
# 3. Result: The bridged interface becomes the active default gateway in the Guest OS.